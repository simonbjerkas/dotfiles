[user]
	name = simonbjerkas
	email = simon.bjerkas10@gmail.com

[pull]
	rebase = false

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = current

[alias]
	undo = reset --soft HEAD^

[core]
	pager = delta

[delta]
	line-numbers = true

[color]
	ui = auto

[color "branch"]
	current = yellow bold
	local = cyan
	remote = green

[color "diff"]
	meta = yellow
	frag = cyan
	old = red
	new = green
	commit = yellow
	whitespace = red reverse

[color "status"]
	added = green
	changed = yellow
	untracked = red
	branch = cyan
	header = white bold

[color "decorate"]
	branch = cyan
	remoteBranch = green
	tag = yellow
	stash = magenta
	head = red bold
