[user]
	name = simonbjerkas
	email = simon.bjerkas10@gmail.com

[pull]
	ff = only

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = current

[alias]
	undo = reset --soft HEAD^
	ss = "!f() { git stash show stash^{/$*} -p; }; f"
	sa = "!f() { git stash apply stash^{/$*}; }; f"
	sl = stash list

[core]
	pager = delta
	editor = nvim

[merge]
	tool = nvim -d

[delta]
	line-numbers = true

[diff]
	algorithm = histogram
	indentHeuristic = true

[protocol]
	version = 2

[help]
	autocorrect = prompt

[url "git@github.com:"]
	insteadOf = gh:

[color]
	ui = auto

[color "branch"]
	current = yellow bold
	local = cyan
	remote = green

[color "diff"]
	meta = yellow
	frag = cyan
	old = red
	new = green
	commit = yellow
	whitespace = red reverse

[color "status"]
	added = green
	changed = yellow
	untracked = red
	branch = cyan
	header = white bold

[color "decorate"]
	branch = cyan
	remoteBranch = green
	tag = yellow
	stash = magenta
	head = red bold
